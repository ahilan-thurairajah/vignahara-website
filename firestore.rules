rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
	// Allow public read access to properties and projects
	match /properties/{docId} {
	  allow read: if true;
	  allow write: if false;
	}

	match /projects/{docId} {
	  allow read: if true;
	  allow write: if false;
	}

	// Inquiries are handled by Cloud Functions, no direct client access needed
	match /inquiries/{docId} {
	  allow read, write: if false;
	}

	match /{document=**} {
	  allow read, write: if false;
	}
  }
}
